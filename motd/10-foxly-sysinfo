#!/usr/bin/env bash
set -u

CONFIG_FILE="${FOXLY_MOTD_CONFIG_FILE:-/etc/default/foxly-motd}"
CACHE_FILE="${FOXLY_MOTD_CACHE_FILE:-/var/cache/foxly-motd/packages}"
STATE_DIR="${FOXLY_MOTD_STATE_DIR:-/var/lib/foxly-motd}"
MEMINFO_FILE="${FOXLY_MOTD_MEMINFO_FILE:-/proc/meminfo}"
RESOLV_CONF_FILE="${FOXLY_MOTD_RESOLV_CONF_FILE:-/etc/resolv.conf}"
REBOOT_REQUIRED_FILE="${FOXLY_MOTD_REBOOT_REQUIRED_FILE:-/var/run/reboot-required}"
MOTD_LANGUAGE=auto
COLOR_MODE=always
SHOW_NETWORK_DETAILS=yes
SHOW_SYSTEM_HEALTH=yes
SHOW_DOCKER=yes
SHOW_PACKAGE_UPDATES=yes
SHOW_UPDATE_NOTICE=yes
# shellcheck source=/dev/null
[[ -r "$CONFIG_FILE" ]] && . "$CONFIG_FILE"

resolve_language() {
    local locale_hint="${LC_ALL:-${LC_MESSAGES:-${LANG:-}}}" locale_lower
    if [[ -z "$locale_hint" && -r /etc/default/locale ]]; then
        locale_hint=$(sed -n 's/^LANG=//p' /etc/default/locale | head -n 1)
        locale_hint=${locale_hint#\"}
        locale_hint=${locale_hint%\"}
    fi
    locale_lower=$(printf '%s' "$locale_hint" | tr '[:upper:]' '[:lower:]')
    case "$MOTD_LANGUAGE" in
        de | en) printf '%s\n' "$MOTD_LANGUAGE" ;;
        auto) [[ "$locale_lower" == de* ]] && printf 'de\n' || printf 'en\n' ;;
        *) printf 'en\n' ;;
    esac
}

LANG_CODE=$(resolve_language)

for flag in SHOW_NETWORK_DETAILS SHOW_SYSTEM_HEALTH SHOW_DOCKER SHOW_PACKAGE_UPDATES SHOW_UPDATE_NOTICE; do
    [[ "${!flag}" == yes || "${!flag}" == no ]] || printf -v "$flag" no
done
case "$COLOR_MODE" in always | never) ;; *) COLOR_MODE=always ;; esac
[[ -n "${FOXLY_MOTD_FORCE_COLOR:-}" ]] && COLOR_MODE=always

COLOR=$'\033[38;5;114m'
GREEN=$'\033[1;32m'
YELLOW=$'\033[1;33m'
RESET=$'\033[0m'
if [[ "$COLOR_MODE" == never ]]; then
    COLOR="" GREEN="" YELLOW="" RESET=""
fi

format_uptime() {
    local seconds=$1 weeks days hours minutes result=""
    weeks=$((seconds / 604800))
    seconds=$((seconds % 604800))
    days=$((seconds / 86400))
    seconds=$((seconds % 86400))
    hours=$((seconds / 3600))
    minutes=$(((seconds % 3600) / 60))
    if [[ "$LANG_CODE" == de ]]; then
        if ((weeks)); then
            ((weeks == 1)) && result="1 Woche" || result="$weeks Wochen"
            ((days)) && result+=", $days $([[ $days -eq 1 ]] && printf Tag || printf Tage)"
        else
            ((days)) && result="$days $([[ $days -eq 1 ]] && printf Tag || printf Tage)"
            ((hours)) && result+="${result:+, }$hours $([[ $hours -eq 1 ]] && printf Stunde || printf Stunden)"
            ((minutes || ${#result} == 0)) && result+="${result:+, }$minutes $([[ $minutes -eq 1 ]] && printf Minute || printf Minuten)"
        fi
    else
        if ((weeks)); then
            result="$weeks $([[ $weeks -eq 1 ]] && printf week || printf weeks)"
            ((days)) && result+=", $days $([[ $days -eq 1 ]] && printf day || printf days)"
        else
            ((days)) && result="$days $([[ $days -eq 1 ]] && printf day || printf days)"
            ((hours)) && result+="${result:+, }$hours $([[ $hours -eq 1 ]] && printf hour || printf hours)"
            ((minutes || ${#result} == 0)) && result+="${result:+, }$minutes $([[ $minutes -eq 1 ]] && printf minute || printf minutes)"
        fi
    fi
    printf '%s\n' "$result"
}

get_ipv4s() {
    local iface address found=no
    command -v ip > /dev/null 2>&1 || {
        printf 'N/A\n'
        return
    }
    while IFS= read -r iface; do
        case "$iface" in lo | docker* | veth* | br-* | virbr* | tun* | tap*) continue ;; esac
        while IFS= read -r address; do
            printf '%s: %s\n' "$iface" "$address"
            found=yes
        done < <(ip -o -4 address show dev "$iface" scope global 2> /dev/null | awk '{print $4}')
    done < <(ip -o link show 2> /dev/null | awk -F': ' '{sub(/@.*/, "", $2); print $2}')
    [[ "$found" == yes ]] || printf 'N/A\n'
}

get_dns_servers() {
    local servers=""
    if command -v resolvectl > /dev/null 2>&1; then
        servers=$(timeout 2 resolvectl dns 2> /dev/null | awk '
            {
                sub(/^[^:]*:[[:space:]]*/, "")
                for (i = 1; i <= NF; i++)
                    if ($i != "-") print $i
            }
        ')
    fi
    if [[ -z "$servers" && -r "$RESOLV_CONF_FILE" ]]; then
        servers=$(awk '$1 == "nameserver" && $2 != "" {print $2}' "$RESOLV_CONF_FILE" 2> /dev/null)
    fi
    if [[ -n "$servers" ]]; then
        printf '%s\n' "$servers" | awk 'NF && !seen[$0]++'
    else
        printf 'N/A\n'
    fi
}

failed_service_count() {
    local units status
    command -v systemctl > /dev/null 2>&1 || {
        printf 'N/A\n'
        return
    }
    units=$(timeout 2 systemctl --failed --type=service --no-legend --plain 2> /dev/null)
    status=$?
    if ((status == 0)); then
        printf '%s\n' "$units" | awk 'NF {count++} END {print count+0}'
    else
        printf 'N/A\n'
    fi
}

memory_usage() {
    awk '
        $1 == "MemTotal:" { total = $2 }
        $1 == "MemAvailable:" { available = $2 }
        $1 == "MemFree:" { free = $2 }
        $1 == "Buffers:" { buffers = $2 }
        $1 == "Cached:" { cached = $2 }
        $1 == "SReclaimable:" { reclaimable = $2 }
        $1 == "Shmem:" { shmem = $2 }
        END {
            if (total <= 0) {
                print "N/A"
                exit
            }
            if (available <= 0)
                available = free + buffers + cached + reclaimable - shmem
            used = total - available
            if (used < 0) used = 0
            if (used > total) used = total
            printf "%.1f%%\n", used * 100 / total
        }
    ' "$MEMINFO_FILE" 2> /dev/null
}

swap_usage() {
    awk '
        $1 == "SwapTotal:" { total = $2 }
        $1 == "SwapFree:" { free = $2 }
        END {
            if (total > 0)
                printf "%.1f%%\n", (total - free) * 100 / total
            else
                print "0.0%"
        }
    ' "$MEMINFO_FILE" 2> /dev/null
}

remote_host() {
    local session
    if [[ -n "${SSH_CONNECTION:-}" ]]; then
        printf '%s\n' "${SSH_CONNECTION%% *}"
    elif [[ -n "${SSH_CLIENT:-}" ]]; then
        printf '%s\n' "${SSH_CLIENT%% *}"
    elif [[ -n "${PAM_RHOST:-}" ]]; then
        printf '%s\n' "$PAM_RHOST"
    elif session=$(who -m 2> /dev/null) && [[ "$session" =~ \(([^()]*)\)[[:space:]]*$ ]]; then
        printf '%s\n' "${BASH_REMATCH[1]}"
    else
        printf 'N/A\n'
    fi
}

cache_value() {
    local key=$1
    [[ -r "$CACHE_FILE" ]] || return 0
    sed -n "s/^${key}=//p" "$CACHE_FILE" | head -n 1
}

cpus=$(nproc 2> /dev/null || printf 1)
load_raw=$(awk '{print $1}' /proc/loadavg 2> /dev/null || printf 0)
load_pct=$(awk -v load="$load_raw" -v cpus="$cpus" 'BEGIN {if (cpus < 1) cpus=1; printf "%.1f%%", load*100/cpus}')
memory_usage=$(memory_usage)
memory_usage=${memory_usage:-N/A}
swap_usage=$(swap_usage)
swap_usage=${swap_usage:-N/A}
disk_free=$(df -P / 2> /dev/null | awk 'NR==2 {printf "%.0f%%", $4*100/$2}')
processes=$(ps -e --no-headers 2> /dev/null | wc -l | tr -d ' ')
uptime_seconds=$(awk '{print int($1)}' /proc/uptime 2> /dev/null || printf 0)

if [[ "$LANG_CODE" == de ]]; then
    heading="Systeminformationen am"
    ip_label="IP-Adresse(n):"
    uptime_label="Systemlaufzeit:"
    load_label="Systemlast:"
    processes_label="Prozesse:"
    memory_label="RAM benutzt:"
    swap_label="Swap benutzt:"
    disk_label="Freier Speicherplatz:"
    user_label="Aktueller Nutzer:"
    dns_label="DNS-Server:"
    failed_services_label="Systemd-Dienste:"
    failed_services_suffix="fehlgeschlagen"
    reboot_label="Neustart nötig:"
    yes_label="Ja"
    no_label="Nein"
    docker_title="Docker-Container"
    docker_active="aktiv"
    docker_stopped="gestoppt"
    docker_unhealthy="fehlerhaft"
    docker_restarting="Neustart"
    network_group="[ NETZWERK ]"
    resources_group="[ RESSOURCEN ]"
    session_group="[ SITZUNG ]"
    health_group="[ SYSTEMSTATUS ]"
else
    heading="System information at"
    ip_label="IP address(es):"
    uptime_label="Uptime:"
    load_label="System load:"
    processes_label="Processes:"
    memory_label="Memory used:"
    swap_label="Swap used:"
    disk_label="Free disk space:"
    user_label="Current user:"
    dns_label="DNS servers:"
    failed_services_label="Systemd services:"
    failed_services_suffix="failed"
    reboot_label="Reboot required:"
    yes_label="Yes"
    no_label="No"
    docker_title="Docker containers"
    docker_active="running"
    docker_stopped="stopped"
    docker_unhealthy="unhealthy"
    docker_restarting="restarting"
    network_group="[ NETWORK ]"
    resources_group="[ RESOURCES ]"
    session_group="[ SESSION ]"
    health_group="[ SYSTEM HEALTH ]"
fi

localize_number() {
    [[ "$LANG_CODE" == de ]] && printf '%s\n' "${1/./,}" || printf '%s\n' "$1"
}

print_dashboard_row() {
    local left_label=$1 left_value=$2 right_label=$3 right_value=$4
    printf '%s%-21s%s %-28s %s%-18s%s %s\n' \
        "$COLOR" "$left_label" "$RESET" "$left_value" \
        "$COLOR" "$right_label" "$RESET" "$right_value"
}

print_status_row() {
    local left_label=$1 left_value=$2 left_color=$3 right_label=$4 right_value=$5 right_color=$6
    local left_padding=$((28 - ${#left_value}))
    ((left_padding < 0)) && left_padding=0
    printf '%s%-21s%s %s%s%s%*s %s%-18s%s %s%s%s\n' \
        "$COLOR" "$left_label" "$RESET" "$left_color" "$left_value" "$RESET" "$left_padding" '' \
        "$COLOR" "$right_label" "$RESET" "$right_color" "$right_value" "$RESET"
}

print_left_continuation() {
    printf '%-21s %-28s\n' '' "$1"
}

print_detail_row() {
    local label=$1 value=$2
    printf '%s%-21s%s %s\n' "$COLOR" "$label" "$RESET" "$value"
}

print_group_heading() {
    printf '%s%s%s\n' "$GREEN" "$1" "$RESET"
}

print_box() {
    local content=$1 horizontal line padding width=0 i
    local -a colored_lines plain_lines
    colored_lines=()
    plain_lines=()
    while IFS= read -r line; do
        colored_lines+=("$line")
    done <<< "$content"
    while IFS= read -r line; do
        plain_lines+=("$line")
    done < <(printf '%s\n' "$content" | sed $'s/\033\\[[0-9;]*m//g')
    for line in "${plain_lines[@]}"; do
        ((${#line} > width)) && width=${#line}
    done
    printf -v horizontal '%*s' "$((width + 2))" ''
    horizontal=${horizontal// /─}
    printf '%s╭%s╮%s\n' "$COLOR" "$horizontal" "$RESET"
    for ((i = 0; i < ${#colored_lines[@]}; i++)); do
        padding=$((width - ${#plain_lines[i]}))
        printf '%s│%s %s%*s %s│%s\n' \
            "$COLOR" "$RESET" "${colored_lines[i]}" "$padding" '' "$COLOR" "$RESET"
    done
    printf '%s╰%s╯%s\n' "$COLOR" "$horizontal" "$RESET"
}

dashboard_output=$(
    printf '%s%s %s%s\n\n' "$COLOR" "$heading" "$(date '+%d.%m.%Y %H:%M:%S')" "$RESET"

    ip_lines=()
    while IFS= read -r ip_line; do
        if ((${#ip_line} > 28)) && [[ "$ip_line" == *': '* ]]; then
            ip_lines+=("${ip_line%%: *}:")
            ip_line="  ${ip_line#*: }"
        fi
        while ((${#ip_line} > 28)); do
            ip_lines+=("${ip_line:0:28}")
            ip_line=${ip_line:28}
        done
        ip_lines+=("$ip_line")
    done < <(get_ipv4s)

    dns_lines=()
    if [[ "$SHOW_NETWORK_DETAILS" == yes ]]; then
        while IFS= read -r dns_line; do
            while ((${#dns_line} > 28)); do
                dns_lines+=("${dns_line:0:28}")
                dns_line=${dns_line:28}
            done
            dns_lines+=("$dns_line")
        done < <(get_dns_servers)
    fi

    print_group_heading "$network_group"
    print_detail_row "$ip_label" "${ip_lines[0]:-N/A}"
    for ((i = 1; i < ${#ip_lines[@]}; i++)); do
        print_left_continuation "${ip_lines[$i]}"
    done
    if [[ "$SHOW_NETWORK_DETAILS" == yes ]]; then
        print_detail_row "$dns_label" "${dns_lines[0]:-N/A}"
        for ((i = 1; i < ${#dns_lines[@]}; i++)); do
            print_left_continuation "${dns_lines[$i]}"
        done
    fi

    printf '\n'

    print_group_heading "$resources_group"
    print_dashboard_row "$load_label" "$(localize_number "$load_pct")" "$processes_label" "$processes"
    print_dashboard_row "$memory_label" "$(localize_number "$memory_usage")" "$swap_label" "$(localize_number "$swap_usage")"
    print_detail_row "$disk_label" "$disk_free"

    printf '\n'

    print_group_heading "$session_group"
    print_detail_row "$uptime_label" "$(format_uptime "$uptime_seconds")"
    print_detail_row "$user_label" "$(id -un)"
    print_detail_row 'Remote Host:' "$(remote_host)"

    if [[ "$SHOW_SYSTEM_HEALTH" == yes ]]; then
        printf '\n'
        print_group_heading "$health_group"
        failed_services=$(failed_service_count)
        failed_color=$GREEN
        [[ "$failed_services" =~ ^[0-9]+$ ]] || failed_color=$YELLOW
        [[ "$failed_services" =~ ^[1-9][0-9]*$ ]] && failed_color=$YELLOW
        reboot_required=$no_label
        reboot_color=$GREEN
        if [[ -e "$REBOOT_REQUIRED_FILE" ]]; then
            reboot_required=$yes_label
            reboot_color=$YELLOW
        fi
        print_status_row "$failed_services_label" "$failed_services $failed_services_suffix" "$failed_color" \
            "$reboot_label" "$reboot_required" "$reboot_color"
    fi
)
print_box "$dashboard_output"
printf '\n'

if [[ "$SHOW_DOCKER" == yes ]] && command -v docker > /dev/null 2>&1; then
    docker_rows=$(timeout 2 docker ps -a --format '{{.State}}\t{{.Status}}' 2> /dev/null)
    docker_status=$?
    if ((docker_status != 0)); then
        if [[ "$LANG_CODE" == de ]]; then
            printf '%s🐳 Docker:%s keine Berechtigung oder Dienst nicht erreichbar\n\n' "$YELLOW" "$RESET"
        else
            printf '%s🐳 Docker:%s permission denied or service unavailable\n\n' "$YELLOW" "$RESET"
        fi
    else
        running=$(printf '%s\n' "$docker_rows" | awk '$1 == "running" {count++} END {print count+0}')
        stopped=$(printf '%s\n' "$docker_rows" | awk '$1 == "exited" || $1 == "dead" {count++} END {print count+0}')
        unhealthy=$(printf '%s\n' "$docker_rows" | awk 'index($0, "(unhealthy)") {count++} END {print count+0}')
        restarting=$(printf '%s\n' "$docker_rows" | awk '$1 == "restarting" {count++} END {print count+0}')
        printf '%s🐳 %s%s  %s%s: %s%s · %s%s: %s%s · %s%s: %s%s · %s%s: %s%s\n\n' \
            "$COLOR" "$docker_title" "$RESET" \
            "$GREEN" "$docker_active" "$running" "$RESET" \
            "$YELLOW" "$docker_stopped" "$stopped" "$RESET" \
            "$YELLOW" "$docker_unhealthy" "$unhealthy" "$RESET" \
            "$YELLOW" "$docker_restarting" "$restarting" "$RESET"
    fi
fi

if [[ "$SHOW_PACKAGE_UPDATES" == yes ]]; then
    updates=$(cache_value updates)
    security=$(cache_value security)
    generated=$(cache_value generated)
    packages=$(cache_value packages)
    if [[ "$updates" =~ ^[0-9]+$ ]]; then
        if ((updates)); then
            if [[ "$LANG_CODE" == de ]]; then
                printf '%s📦 %s Paket-Updates verfügbar, davon %s Sicherheitsupdates.%s\n' "$COLOR" "$updates" "${security:-0}" "$RESET"
            else
                printf '%s📦 %s package updates available, including %s security updates.%s\n' "$COLOR" "$updates" "${security:-0}" "$RESET"
            fi
            [[ -n "$packages" ]] && printf '   %s\n' "$packages"
        else
            if [[ "$LANG_CODE" == de ]]; then
                printf '%s📦 Keine Paket-Updates im letzten Cache-Lauf.%s\n' "$COLOR" "$RESET"
            else
                printf '%s📦 No package updates in the latest cache run.%s\n' "$COLOR" "$RESET"
            fi
        fi
        [[ -n "$generated" ]] && printf '   Cache: %s\n' "$generated"
    else
        if [[ "$LANG_CODE" == de ]]; then
            printf '%s📦 Update-Cache wird beim nächsten Timer-Lauf erstellt.%s\n' "$YELLOW" "$RESET"
        else
            printf '%s📦 The update cache will be created by the next timer run.%s\n' "$YELLOW" "$RESET"
        fi
    fi
fi

if [[ "$SHOW_UPDATE_NOTICE" == yes && -r "$STATE_DIR/version" && -r "$STATE_DIR/latest-version" ]]; then
    current=$(head -n 1 "$STATE_DIR/version")
    latest=$(head -n 1 "$STATE_DIR/latest-version")
    if [[ -n "$latest" && "$latest" != "$current" ]]; then
        if [[ "$LANG_CODE" == de ]]; then
            printf '\n%s⬆ Foxly MOTD %s ist verfügbar: sudo foxly-motd update%s\n' "$YELLOW" "$latest" "$RESET"
        else
            printf '\n%s⬆ Foxly MOTD %s is available: sudo foxly-motd update%s\n' "$YELLOW" "$latest" "$RESET"
        fi
    fi
fi
